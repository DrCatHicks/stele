# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored (it can hold
# environment-specific values; secrets are generated by the module, not set here).
#
# The Railway API token is NOT a variable — export it in your shell:
#   export RAILWAY_TOKEN=...        # a workspace/account token, not a project token

project_name     = "stele"
environment_name = "production"
region           = "us-east4"

# The repo Railway builds the web service from. Install the Railway GitHub app on
# this repo first, or the build can't pull source.
source_repo        = "countercheck/stele"
source_repo_branch = "main"

# Attach a public Railway domain (https://<web_subdomain>-<hash>.up.railway.app).
# Leave empty to deploy internal-only / attach a custom domain out of band.
web_subdomain = "stele-demo"

# database_name      = "stele"
# workspace_id       = ""   # default workspace of the token
# postgres_image     = "ghcr.io/railwayapp-templates/postgres-ssl:16"
# cookie_secure      = true
# etl_cron_schedule  = "0 6 * * *"   # daily 06:00 UTC; UTC cron expression

# Public Postgres endpoint for analyst/reviewer direct (M3.5) access. OFF by
# default — a standing public 5432 is a deliberate exposure. Flip on when someone
# needs warehouse access; `tofu output postgres_proxy` then gives the host:port.
# enable_postgres_proxy = false

# Operator-supplied secret overrides (rotation / real-prod path). Empty = the
# module GENERATES the password (the demo default). After rotating a live role
# with scripts/rotate_role_password.py, set the matching override here to the new
# value and re-apply, so the services' connection strings track the live role.
# See docs/verification/m7.6-demo-to-prod.md § Secret rotation. NEVER commit real
# secrets — terraform.tfvars is gitignored, but treat these as you would any key.
# admin_password_override              = ""
# stele_api_password_override          = ""
# stele_etl_password_override          = ""
# stele_analyst_password_override      = ""
# stele_pii_reviewer_password_override = ""
