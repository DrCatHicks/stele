# Railway auth for the OpenTofu provider. Copy to `.env` (gitignored) and fill in.
# Source it before running tofu:   source .env && tofu plan
#
# This is the provider's auth token ONLY. It is deliberately NOT a tofu variable
# (provider credentials don't belong in tfvars or state). The role passwords are
# GENERATED by the module into tfstate — retrieve them with `tofu output -raw …`,
# don't put them here.
#
# Use a WORKSPACE/ACCOUNT token (a project token can't create projects).
export RAILWAY_TOKEN="rwy_..."

# Note: the Railway CLI is a separate tool with separate auth. It reads the
# account token as RAILWAY_API_TOKEN (not RAILWAY_TOKEN) — or just `railway login`
# via browser once and it caches creds in ~/.railway. Don't source this file in a
# shell where you run the CLI, or the CLI will try to use RAILWAY_TOKEN as a
# project token and reject it.
